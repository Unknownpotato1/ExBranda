// ExBranda — Prisma schema
// Note: In production this maps to Firebase Firestore collections.
// Each model below corresponds to a Firestore collection of the same name.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  name              String?
  // Onboarding fields
  fullName          String?
  instagramHandle   String?
  country           String?
  upiId             String?
  referralCode      String   @unique
  referredBy        String?  // referral code of inviter
  referralActive    Boolean  @default(false) // becomes true after first successful withdrawal by a referred user (inviter side)
  referralBonusPct  Float    @default(0) // 0 or 5 (percent added to base rate)
  // Role
  role              String   @default("user") // "user" | "admin"
  banned            Boolean  @default(false)
  // Display prefs
  privacyHideWallet Boolean  @default(false)
  // Badges (JSON string array stored as text in SQLite)
  badges            String   @default("[]")
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  wallet            Wallet?
  submissions       Submission[]
  withdrawals       Withdrawal[]
  transactions      Transaction[]
  notifications     Notification[]
  downloads         Download[]
  referralsMade     Referral[]     @relation("Referrer")
  referralsReceived Referral[]     @relation("Referred")
  auditLogs         AuditLog[]
}

model Wallet {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance         Float    @default(0) // available for withdrawal
  pendingBalance  Float    @default(0) // pending approval
  lifetimeEarnings Float   @default(0)
  withdrawnTotal  Float    @default(0)
  todayEarnings   Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Transaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String   // "earning" | "withdrawal" | "referral_bonus" | "adjustment"
  amount       Float
  status       String   @default("completed") // "completed" | "pending" | "rejected"
  description  String
  reelUrl      String?
  views        Int?
  submissionId String?
  createdAt    DateTime @default(now())
}

model Submission {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reelUrl         String
  // View tracking — core duplicate-prevention logic
  currentViews    Int      // total views submitted this time
  previousApprovedViews Int @default(0) // sum of all approved views so far for this reel
  newViews        Int      @default(0) // currentViews - previousApprovedViews (delta)
  approvedViews   Int      @default(0) // views approved from this submission
  rejectedViews   Int      @default(0)
  // Payout
  payoutAmount    Float    @default(0)
  ratePer10k      Float    @default(100)
  // State
  status          String   @default("pending") // "pending" | "approved" | "rejected"
  notes           String?
  rejectionReason String?
  approvedAt      DateTime?
  approvedBy      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, reelUrl])
  @@index([status])
}

model Withdrawal {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Float
  upiId        String
  status       String   @default("pending") // "pending" | "approved" | "rejected" | "paid"
  rejectedReason String?
  paidAt       DateTime?
  paidBy       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

model Referral {
  id           String   @id @default(cuid())
  referrerId   String
  referrer     User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId   String
  referred     User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  code         String
  status       String   @default("pending") // "pending" | "active" | "rejected"
  activatedAt  DateTime?
  bonusType    String   @default("rate_5pct") // "rate_5pct" | "fixed_inr"
  bonusValue   Float    @default(0)
  createdAt    DateTime @default(now())

  @@unique([referredId]) // only first referral counts
}

model Setting {
  id           String   @id @default(cuid())
  key          String   @unique
  value        String
  updatedAt    DateTime @updatedAt
}

model Admin {
  id           String   @id @default(cuid())
  userId       String   @unique
  createdAt    DateTime @default(now())
}

model Notification {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  message      String
  type         String   // "submission_approved" | "submission_rejected" | "withdrawal_paid" | "referral_activated" | "bonus_increased" | "broadcast"
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([userId, read])
}

model Download {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileType     String   // "png" | "transparent_png" | "svg" | "zip"
  createdAt    DateTime @default(now())
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  actor        User?    @relation(fields: [actorId], references: [id])
  action       String
  target       String?
  meta         String?
  createdAt    DateTime @default(now())
}
