# ExBranda Environment Variables

# === Firebase (server-side) ===
# The full service account JSON, single-line escaped.
# Get this from Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then JSON.stringify(require("./service-account.json"))
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"exbranda",...}

# === Firebase (client-side, public) ===
# Get this from Firebase Console → Project Settings → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_CONFIG={"apiKey":"...","authDomain":"exbranda.firebaseapp.com","projectId":"exbranda","storageBucket":"exbranda.firebasestorage.app","messagingSenderId":"771397020397","appId":"1:771397020397:web:..."}

# OR set individual env vars (less preferred):
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=exbranda.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=exbranda
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=exbranda.firebasestorage.app
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=771397020397
# NEXT_PUBLIC_FIREBASE_APP_ID=

# === Cloudinary (logo storage) ===
CLOUDINARY_CLOUD_NAME=drlmgjt6p
CLOUDINARY_API_KEY=345436599581327
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# === App ===
NEXT_PUBLIC_APP_URL=https://exbranda.vercel.app
