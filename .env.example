# ExBranda Environment Variables

# Database (dev: SQLite, prod: PostgreSQL or Firestore)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Cloudinary (logo storage) — required for /api/downloads/asset
CLOUDINARY_CLOUD_NAME=drlmgjt6p
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Firebase (production — see README for swap instructions)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# App
NEXT_PUBLIC_APP_URL=https://exbranda.com
